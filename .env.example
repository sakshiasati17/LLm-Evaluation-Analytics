APP_NAME=LLM Evaluation & Monitoring Platform
APP_ENV=dev
MODELS_CONFIG_PATH=config/models.yaml

# Provider API keys (leave blank to use mock-local for free local testing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=
OPENROUTER_API_KEY=

# LLM-as-judge: set to any model_id from config/models.yaml to enable semantic scoring
# When set, accuracy and hallucination are scored by this model instead of heuristics
# Recommended: gpt-4o-mini (fast, cheap, accurate judge)
# Leave blank to use enhanced heuristic scoring (works offline)
JUDGE_MODEL_ID=

# Platform API key — if set, all /api/v1/* endpoints require X-API-Key header
# Protects against unauthorized use of provider API keys
# Leave blank to disable auth (fine for local dev)
PLATFORM_API_KEY=

# Database (optional — JSON artifact files used by default)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/llm_eval

# Run artifact storage directory
RUN_ARTIFACT_DIR=artifacts/runs

# Alerts on CI gate failures
ALERT_ON_GATE_FAIL=false
SLACK_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
ALERT_TO_EMAILS=
